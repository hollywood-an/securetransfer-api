{
  "info": {
    "_postman_id": "b2f1c0a0-0000-4000-8000-securetransfer1",
    "name": "SecureTransfer API",
    "description": "SecureTransfer API requests.\n\nPhase 1: customers & accounts. Phase 2: transfers. Phase 3: idempotency. Phase 4: JWT auth + roles.\n\nRun top-to-bottom. It registers a CUSTOMER (alice), logs in the seeded admin to open accounts, logs alice in, and then exercises the allowed actions plus the denied ones (403) and unauthenticated ones (401). Tokens and ids are chained automatically via collection variables.\n\nThe app must be running (./gradlew bootRun) on {{baseUrl}} with the seeded admin password = admin12345.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:8080", "type": "string" },
    { "key": "aliceUsername", "value": "", "type": "string" },
    { "key": "customerToken", "value": "", "type": "string" },
    { "key": "adminToken", "value": "", "type": "string" },
    { "key": "aliceCustomerId", "value": "", "type": "string" },
    { "key": "bobCustomerId", "value": "", "type": "string" },
    { "key": "fromAccountId", "value": "", "type": "string" },
    { "key": "toAccountId", "value": "", "type": "string" },
    { "key": "transferKey", "value": "", "type": "string" },
    { "key": "firstTransferId", "value": "", "type": "string" },
    { "key": "fraudReviewId", "value": "", "type": "string" }
  ],
  "item": [
    {
      "name": "Register Customer (alice)",
      "event": [
        { "listen": "prerequest", "script": { "type": "text/javascript", "exec": [
          "pm.collectionVariables.set('aliceUsername', 'alice-' + pm.variables.replaceIn('{{$guid}}'));"
        ] } },
        { "listen": "test", "script": { "type": "text/javascript", "exec": [
          "pm.test('status is 201 Created', () => pm.response.to.have.status(201));",
          "const b = pm.response.json();",
          "pm.test('role is CUSTOMER', () => pm.expect(b.role).to.eql('CUSTOMER'));",
          "pm.collectionVariables.set('aliceCustomerId', b.customerId);"
        ] } }
      ],
      "request": {
        "method": "POST",
        "header": [ { "key": "Content-Type", "value": "application/json" } ],
        "body": { "mode": "raw", "raw": "{\n  \"username\": \"{{aliceUsername}}\",\n  \"password\": \"alicepw123\",\n  \"name\": \"Alice Example\",\n  \"email\": \"{{$randomEmail}}\"\n}" },
        "url": { "raw": "{{baseUrl}}/auth/register", "host": [ "{{baseUrl}}" ], "path": [ "auth", "register" ] }
      }
    },
    {
      "name": "Register Customer (bob)",
      "event": [
        { "listen": "test", "script": { "type": "text/javascript", "exec": [
          "pm.test('status is 201 Created', () => pm.response.to.have.status(201));",
          "pm.collectionVariables.set('bobCustomerId', pm.response.json().customerId);"
        ] } }
      ],
      "request": {
        "method": "POST",
        "header": [ { "key": "Content-Type", "value": "application/json" } ],
        "body": { "mode": "raw", "raw": "{\n  \"username\": \"bob-{{$guid}}\",\n  \"password\": \"bobpw1234\",\n  \"name\": \"Bob Example\",\n  \"email\": \"{{$randomEmail}}\"\n}" },
        "url": { "raw": "{{baseUrl}}/auth/register", "host": [ "{{baseUrl}}" ], "path": [ "auth", "register" ] }
      }
    },
    {
      "name": "Login as admin (seeded)",
      "event": [
        { "listen": "test", "script": { "type": "text/javascript", "exec": [
          "pm.test('status is 200 OK', () => pm.response.to.have.status(200));",
          "const b = pm.response.json();",
          "pm.test('role is ADMIN', () => pm.expect(b.role).to.eql('ADMIN'));",
          "pm.collectionVariables.set('adminToken', b.token);"
        ] } }
      ],
      "request": {
        "method": "POST",
        "header": [ { "key": "Content-Type", "value": "application/json" } ],
        "body": { "mode": "raw", "raw": "{\n  \"username\": \"admin\",\n  \"password\": \"admin12345\"\n}" },
        "url": { "raw": "{{baseUrl}}/auth/login", "host": [ "{{baseUrl}}" ], "path": [ "auth", "login" ] }
      }
    },
    {
      "name": "Admin: open account A for alice (balance 100)",
      "event": [
        { "listen": "test", "script": { "type": "text/javascript", "exec": [
          "pm.test('status is 201 Created', () => pm.response.to.have.status(201));",
          "pm.collectionVariables.set('fromAccountId', pm.response.json().id);"
        ] } }
      ],
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "Authorization", "value": "Bearer {{adminToken}}" }
        ],
        "body": { "mode": "raw", "raw": "{\n  \"customerId\": {{aliceCustomerId}},\n  \"currency\": \"USD\",\n  \"initialBalance\": 100.00\n}" },
        "url": { "raw": "{{baseUrl}}/accounts", "host": [ "{{baseUrl}}" ], "path": [ "accounts" ] }
      }
    },
    {
      "name": "Admin: open account B for bob (balance 0)",
      "event": [
        { "listen": "test", "script": { "type": "text/javascript", "exec": [
          "pm.test('status is 201 Created', () => pm.response.to.have.status(201));",
          "pm.collectionVariables.set('toAccountId', pm.response.json().id);"
        ] } }
      ],
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "Authorization", "value": "Bearer {{adminToken}}" }
        ],
        "body": { "mode": "raw", "raw": "{\n  \"customerId\": {{bobCustomerId}},\n  \"currency\": \"USD\"\n}" },
        "url": { "raw": "{{baseUrl}}/accounts", "host": [ "{{baseUrl}}" ], "path": [ "accounts" ] }
      }
    },
    {
      "name": "Login as alice (customer)",
      "event": [
        { "listen": "test", "script": { "type": "text/javascript", "exec": [
          "pm.test('status is 200 OK', () => pm.response.to.have.status(200));",
          "pm.collectionVariables.set('customerToken', pm.response.json().token);"
        ] } }
      ],
      "request": {
        "method": "POST",
        "header": [ { "key": "Content-Type", "value": "application/json" } ],
        "body": { "mode": "raw", "raw": "{\n  \"username\": \"{{aliceUsername}}\",\n  \"password\": \"alicepw123\"\n}" },
        "url": { "raw": "{{baseUrl}}/auth/login", "host": [ "{{baseUrl}}" ], "path": [ "auth", "login" ] }
      }
    },
    {
      "name": "Alice: GET own account A (-> 200)",
      "event": [
        { "listen": "test", "script": { "type": "text/javascript", "exec": [
          "pm.test('status is 200 OK', () => pm.response.to.have.status(200));"
        ] } }
      ],
      "request": {
        "method": "GET",
        "header": [ { "key": "Authorization", "value": "Bearer {{customerToken}}" } ],
        "url": { "raw": "{{baseUrl}}/accounts/{{fromAccountId}}", "host": [ "{{baseUrl}}" ], "path": [ "accounts", "{{fromAccountId}}" ] }
      }
    },
    {
      "name": "Alice: transfer A -> B, 30.00 (-> 201)",
      "event": [
        { "listen": "prerequest", "script": { "type": "text/javascript", "exec": [
          "pm.collectionVariables.set('transferKey', 'tx-' + pm.variables.replaceIn('{{$guid}}'));"
        ] } },
        { "listen": "test", "script": { "type": "text/javascript", "exec": [
          "pm.test('status is 201 Created', () => pm.response.to.have.status(201));",
          "const b = pm.response.json();",
          "pm.collectionVariables.set('firstTransferId', b.id);",
          "pm.test('sender balance is now 70', () => pm.expect(Number(b.fromBalance)).to.eql(70));"
        ] } }
      ],
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "Authorization", "value": "Bearer {{customerToken}}" },
          { "key": "Idempotency-Key", "value": "{{transferKey}}" }
        ],
        "body": { "mode": "raw", "raw": "{\n  \"fromAccount\": {{fromAccountId}},\n  \"toAccount\": {{toAccountId}},\n  \"amount\": 30.00\n}" },
        "url": { "raw": "{{baseUrl}}/transfers", "host": [ "{{baseUrl}}" ], "path": [ "transfers" ] }
      }
    },
    {
      "name": "Alice: replay transfer (same key -> money once)",
      "event": [
        { "listen": "test", "script": { "type": "text/javascript", "exec": [
          "pm.test('status is 201 Created', () => pm.response.to.have.status(201));",
          "const b = pm.response.json();",
          "pm.test('same transfer id (replayed)', () => pm.expect(String(b.id)).to.eql(pm.collectionVariables.get('firstTransferId')));",
          "pm.test('sender balance still 70 (money moved once)', () => pm.expect(Number(b.fromBalance)).to.eql(70));"
        ] } }
      ],
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "Authorization", "value": "Bearer {{customerToken}}" },
          { "key": "Idempotency-Key", "value": "{{transferKey}}" }
        ],
        "body": { "mode": "raw", "raw": "{\n  \"fromAccount\": {{fromAccountId}},\n  \"toAccount\": {{toAccountId}},\n  \"amount\": 30.00\n}" },
        "url": { "raw": "{{baseUrl}}/transfers", "host": [ "{{baseUrl}}" ], "path": [ "transfers" ] }
      }
    },
    {
      "name": "Alice: GET bob's account B (-> 403)",
      "event": [
        { "listen": "test", "script": { "type": "text/javascript", "exec": [
          "pm.test('status is 403 Forbidden', () => pm.response.to.have.status(403));"
        ] } }
      ],
      "request": {
        "method": "GET",
        "header": [ { "key": "Authorization", "value": "Bearer {{customerToken}}" } ],
        "url": { "raw": "{{baseUrl}}/accounts/{{toAccountId}}", "host": [ "{{baseUrl}}" ], "path": [ "accounts", "{{toAccountId}}" ] }
      }
    },
    {
      "name": "Alice: transfer FROM bob's account (-> 403)",
      "event": [
        { "listen": "test", "script": { "type": "text/javascript", "exec": [
          "pm.test('status is 403 Forbidden', () => pm.response.to.have.status(403));"
        ] } }
      ],
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "Authorization", "value": "Bearer {{customerToken}}" },
          { "key": "Idempotency-Key", "value": "{{$guid}}" }
        ],
        "body": { "mode": "raw", "raw": "{\n  \"fromAccount\": {{toAccountId}},\n  \"toAccount\": {{fromAccountId}},\n  \"amount\": 10.00\n}" },
        "url": { "raw": "{{baseUrl}}/transfers", "host": [ "{{baseUrl}}" ], "path": [ "transfers" ] }
      }
    },
    {
      "name": "Alice: POST /customers (staff-only -> 403)",
      "event": [
        { "listen": "test", "script": { "type": "text/javascript", "exec": [
          "pm.test('status is 403 Forbidden', () => pm.response.to.have.status(403));"
        ] } }
      ],
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "Authorization", "value": "Bearer {{customerToken}}" }
        ],
        "body": { "mode": "raw", "raw": "{\n  \"name\": \"Nope\",\n  \"email\": \"nope@example.com\"\n}" },
        "url": { "raw": "{{baseUrl}}/customers", "host": [ "{{baseUrl}}" ], "path": [ "customers" ] }
      }
    },
    {
      "name": "Alice: GET /admin/users (admin-only -> 403)",
      "event": [
        { "listen": "test", "script": { "type": "text/javascript", "exec": [
          "pm.test('status is 403 Forbidden', () => pm.response.to.have.status(403));"
        ] } }
      ],
      "request": {
        "method": "GET",
        "header": [ { "key": "Authorization", "value": "Bearer {{customerToken}}" } ],
        "url": { "raw": "{{baseUrl}}/admin/users", "host": [ "{{baseUrl}}" ], "path": [ "admin", "users" ] }
      }
    },
    {
      "name": "No token: GET account (-> 401)",
      "event": [
        { "listen": "test", "script": { "type": "text/javascript", "exec": [
          "pm.test('status is 401 Unauthorized', () => pm.response.to.have.status(401));"
        ] } }
      ],
      "request": {
        "method": "GET",
        "header": [],
        "url": { "raw": "{{baseUrl}}/accounts/{{fromAccountId}}", "host": [ "{{baseUrl}}" ], "path": [ "accounts", "{{fromAccountId}}" ] }
      }
    },
    {
      "name": "Admin: GET /admin/users (-> 200)",
      "event": [
        { "listen": "test", "script": { "type": "text/javascript", "exec": [
          "pm.test('status is 200 OK', () => pm.response.to.have.status(200));",
          "pm.test('returns a list of users', () => pm.expect(pm.response.json()).to.be.an('array'));"
        ] } }
      ],
      "request": {
        "method": "GET",
        "header": [ { "key": "Authorization", "value": "Bearer {{adminToken}}" } ],
        "url": { "raw": "{{baseUrl}}/admin/users", "host": [ "{{baseUrl}}" ], "path": [ "admin", "users" ] }
      }
    },
    {
      "name": "Admin: freeze account A (-> 200, FROZEN)",
      "event": [
        { "listen": "test", "script": { "type": "text/javascript", "exec": [
          "pm.test('status is 200 OK', () => pm.response.to.have.status(200));",
          "pm.test('account is FROZEN', () => pm.expect(pm.response.json().status).to.eql('FROZEN'));"
        ] } }
      ],
      "request": {
        "method": "POST",
        "header": [ { "key": "Authorization", "value": "Bearer {{adminToken}}" } ],
        "url": { "raw": "{{baseUrl}}/admin/accounts/{{fromAccountId}}/freeze", "host": [ "{{baseUrl}}" ], "path": [ "admin", "accounts", "{{fromAccountId}}", "freeze" ] }
      }
    },
    {
      "name": "Transfer from frozen account A (-> 409)",
      "event": [
        { "listen": "test", "script": { "type": "text/javascript", "exec": [
          "pm.test('status is 409 Conflict', () => pm.response.to.have.status(409));"
        ] } }
      ],
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "Authorization", "value": "Bearer {{customerToken}}" },
          { "key": "Idempotency-Key", "value": "{{$guid}}" }
        ],
        "body": { "mode": "raw", "raw": "{\n  \"fromAccount\": {{fromAccountId}},\n  \"toAccount\": {{toAccountId}},\n  \"amount\": 1.00\n}" },
        "url": { "raw": "{{baseUrl}}/transfers", "host": [ "{{baseUrl}}" ], "path": [ "transfers" ] }
      }
    },
    {
      "name": "Admin: GET /audit (-> 200, shows the freeze)",
      "event": [
        { "listen": "test", "script": { "type": "text/javascript", "exec": [
          "pm.test('status is 200 OK', () => pm.response.to.have.status(200));",
          "const body = pm.response.json();",
          "pm.test('paginated with content', () => pm.expect(body.content).to.be.an('array'));",
          "pm.test('most recent entry is the freeze by admin', () => {",
          "  pm.expect(body.content.length).to.be.above(0);",
          "  pm.expect(body.content[0].action).to.eql('ACCOUNT_FROZEN');",
          "  pm.expect(body.content[0].actor).to.eql('admin');",
          "});"
        ] } }
      ],
      "request": {
        "method": "GET",
        "header": [ { "key": "Authorization", "value": "Bearer {{adminToken}}" } ],
        "url": {
          "raw": "{{baseUrl}}/audit?action=ACCOUNT_FROZEN&page=0&size=20",
          "host": [ "{{baseUrl}}" ],
          "path": [ "audit" ],
          "query": [
            { "key": "action", "value": "ACCOUNT_FROZEN" },
            { "key": "page", "value": "0" },
            { "key": "size", "value": "20" }
          ]
        }
      }
    },
    {
      "name": "Customer: GET /audit (-> 403)",
      "event": [
        { "listen": "test", "script": { "type": "text/javascript", "exec": [
          "pm.test('status is 403 Forbidden', () => pm.response.to.have.status(403));"
        ] } }
      ],
      "request": {
        "method": "GET",
        "header": [ { "key": "Authorization", "value": "Bearer {{customerToken}}" } ],
        "url": { "raw": "{{baseUrl}}/audit", "host": [ "{{baseUrl}}" ], "path": [ "audit" ] }
      }
    },
    {
      "name": "Admin: unfreeze account A (-> 200, ACTIVE)",
      "event": [
        { "listen": "test", "script": { "type": "text/javascript", "exec": [
          "pm.test('status is 200 OK', () => pm.response.to.have.status(200));",
          "pm.test('account is ACTIVE again', () => pm.expect(pm.response.json().status).to.eql('ACTIVE'));"
        ] } }
      ],
      "request": {
        "method": "POST",
        "header": [ { "key": "Authorization", "value": "Bearer {{adminToken}}" } ],
        "url": { "raw": "{{baseUrl}}/admin/accounts/{{fromAccountId}}/unfreeze", "host": [ "{{baseUrl}}" ], "path": [ "admin", "accounts", "{{fromAccountId}}", "unfreeze" ] }
      }
    },
    {
      "name": "Alice: large transfer A -> B 20000 (flagged, still completes)",
      "event": [
        { "listen": "test", "script": { "type": "text/javascript", "exec": [
          "pm.test('status is 201 Created', () => pm.response.to.have.status(201));",
          "pm.test('transfer is FLAGGED (large amount) but completed', () => pm.expect(pm.response.json().status).to.eql('FLAGGED'));"
        ] } }
      ],
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "Authorization", "value": "Bearer {{customerToken}}" },
          { "key": "Idempotency-Key", "value": "{{$guid}}" }
        ],
        "body": { "mode": "raw", "raw": "{\n  \"fromAccount\": {{fromAccountId}},\n  \"toAccount\": {{toAccountId}},\n  \"amount\": 20000.00\n}" },
        "url": { "raw": "{{baseUrl}}/transfers", "host": [ "{{baseUrl}}" ], "path": [ "transfers" ] }
      }
    },
    {
      "name": "Admin: fraud-review queue (after a short wait for async review)",
      "event": [
        { "listen": "prerequest", "script": { "type": "text/javascript", "exec": [
          "// the review runs asynchronously; give it a moment before polling",
          "setTimeout(() => {}, 1500);"
        ] } },
        { "listen": "test", "script": { "type": "text/javascript", "exec": [
          "pm.test('status is 200 OK', () => pm.response.to.have.status(200));",
          "const body = pm.response.json();",
          "pm.test('queue has at least one review', () => pm.expect(body.content.length).to.be.above(0));",
          "const review = body.content[0];",
          "pm.collectionVariables.set('fraudReviewId', review.id);",
          "pm.test('review has a risk score and recommended action', () => {",
          "  pm.expect(review).to.have.property('riskScore');",
          "  pm.expect(['APPROVE','HOLD','ESCALATE']).to.include(review.recommendedAction);",
          "});"
        ] } }
      ],
      "request": {
        "method": "GET",
        "header": [ { "key": "Authorization", "value": "Bearer {{adminToken}}" } ],
        "url": {
          "raw": "{{baseUrl}}/fraud-reviews?page=0&size=20",
          "host": [ "{{baseUrl}}" ],
          "path": [ "fraud-reviews" ],
          "query": [ { "key": "page", "value": "0" }, { "key": "size", "value": "20" } ]
        }
      }
    },
    {
      "name": "Customer: GET /fraud-reviews (-> 403)",
      "event": [
        { "listen": "test", "script": { "type": "text/javascript", "exec": [
          "pm.test('status is 403 Forbidden', () => pm.response.to.have.status(403));"
        ] } }
      ],
      "request": {
        "method": "GET",
        "header": [ { "key": "Authorization", "value": "Bearer {{customerToken}}" } ],
        "url": { "raw": "{{baseUrl}}/fraud-reviews", "host": [ "{{baseUrl}}" ], "path": [ "fraud-reviews" ] }
      }
    },
    {
      "name": "Teller: record human decision (HOLD -> DECIDED)",
      "event": [
        { "listen": "test", "script": { "type": "text/javascript", "exec": [
          "pm.test('status is 200 OK', () => pm.response.to.have.status(200));",
          "const b = pm.response.json();",
          "pm.test('review is DECIDED with the human decision', () => {",
          "  pm.expect(b.status).to.eql('DECIDED');",
          "  pm.expect(b.humanDecision).to.eql('HOLD');",
          "});"
        ] } }
      ],
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "Authorization", "value": "Bearer {{adminToken}}" }
        ],
        "body": { "mode": "raw", "raw": "{\n  \"decision\": \"HOLD\"\n}" },
        "url": { "raw": "{{baseUrl}}/fraud-reviews/{{fraudReviewId}}/decision", "host": [ "{{baseUrl}}" ], "path": [ "fraud-reviews", "{{fraudReviewId}}", "decision" ] }
      }
    }
  ]
}
