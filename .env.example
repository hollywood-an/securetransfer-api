# .env.example — TEMPLATE for local secrets.
#
# Copy this file to ".env" and fill in real values:
#     cp .env.example .env
#
# ".env" is gitignored and must NEVER be committed. Both docker-compose
# (automatically) and the app (when you export these) read these values.

# Password for the local PostgreSQL database.
# Used by docker-compose.yml AND by the app's datasource (DB_PASSWORD).
DB_PASSWORD=change-me-local-dev

# Secret key for signing JWT login tokens (Phase 4). MUST be at least 32
# characters. Generate a long random value, e.g.:  openssl rand -base64 48
JWT_SECRET=change-me-to-a-long-random-string-at-least-32-chars

# Passwords for the seeded staff logins (admin / teller). REQUIRED — the app
# won't start without them, so there is no committed default credential. Use
# strong, unique values (and change them outside local dev).
ADMIN_PASSWORD=change-me-admin-password
TELLER_PASSWORD=change-me-teller-password

# Later phases will add more secrets here, for example:
#   ANTHROPIC_API_KEY=...     (Phase 6 — fraud-triage agent)
