# .env.example — TEMPLATE for local secrets.
#
# Copy this file to ".env" and fill in real values:
#     cp .env.example .env
#
# ".env" is gitignored and must NEVER be committed. Both docker-compose
# (automatically) and the app (when you export these) read these values.

# Password for the local PostgreSQL database.
# Used by docker-compose.yml AND by the app's datasource (DB_PASSWORD).
DB_PASSWORD=change-me-local-dev

# Later phases will add more secrets here, for example:
#   JWT_SECRET=...            (Phase 4 — signing key for login tokens)
#   ANTHROPIC_API_KEY=...     (Phase 6 — fraud-triage agent)
